{
  "$schema": "internal — siehe email-holehe-passive.worker.ts für Feld-Doku",
  "version": 1,
  "source": "kuratiert auf Basis von megadose/holehe@v1.61, nur ToS-konforme Module ohne Captcha-Bypass / Brute-Force-Pattern",
  "lastReviewed": "2026-05-08",
  "modules": [
    {
      "name": "adobe",
      "platform": "adobe.com",
      "method": "POST",
      "url": "https://auth.services.adobe.com/signin/v2/users/{email}/status",
      "headers": { "Content-Type": "application/json", "x-ims-clientid": "adobedotcom2" },
      "successCriteria": { "statusCodeIn": [200] },
      "errorCriteria": { "statusCodeIn": [404, 400] },
      "complianceNote": "Public account-status Endpoint, dient der Adobe-Login-UX (forgot-password)."
    },
    {
      "name": "amazon",
      "platform": "amazon.com",
      "method": "POST",
      "url": "https://www.amazon.com/ap/signin",
      "body": { "email": "{email}", "create": "0" },
      "successCriteria": { "responseContains": "We cannot find an account" },
      "errorCriteria": { "statusCodeIn": [403, 503] },
      "complianceNote": "Public Login-Form, leakt Existenz im UI-Text. Kein bot-protection bypass."
    },
    {
      "name": "atlassian",
      "platform": "atlassian.com",
      "method": "POST",
