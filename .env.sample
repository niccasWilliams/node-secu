# ============================================================================
# Node-Template — Environment Variables
# ============================================================================
# Kopiere diese Datei nach .env und passe die Werte an.
# Fuer Produktion: Secrets werden via AMP automatisch gesetzt (siehe amp.manifest.ts)


# ── Infrastructure ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:example@localhost:5450/postgres
HOST_NAME="localhost"
NODE_PORT="8100"
PUBLIC_URL="http://localhost:8100"


# ── Security (in Produktion: auto_generate via AMP) ────────────────────────
API_KEY="replace-with-secure-random-string"
DATA_ENCRYPTION_KEY="replace-with-min-32-char-hex-string"
JWT_SECRET="replace-with-secure-random-string"
CRON_JOB_SECRET="replace-with-secure-random-string"


# ── Auth Mode ──────────────────────────────────────────────────────────────
# "williams" (default) — NextJS-Frontend uebernimmt Auth, signiert JWT mit FRONTEND_API_KEY,
#                        Backend lebt im Internal-Network und vertraut dem JWT.
# "direct"            — serverlose Frontends (Expo, Mobile) sprechen /auth/* direkt an.
AUTH_MODE="williams"


# ── Frontend Connection (AUTH_MODE=williams) ───────────────────────────────
FRONTEND_API_KEY="replace-with-shared-api-key"
FRONTEND_HOST_NAME="localhost:3000"


# ── Direct Auth (AUTH_MODE=direct) ─────────────────────────────────────────
# Zwei separate Secrets fuer Access- und Refresh-JWT (Schluesseltrennung,
# erlaubt unabhaengige Rotation). Mindestens 32 zufaellige Bytes je Secret.
# Email-Verification ist im direct-Mode immer Pflicht; der Verification-Link
# zeigt auf ${PUBLIC_URL}/auth/verify-email?token=… und wird vom Backend
# selbst als Landing-Page gerendert.
# AUTH_JWT_ACCESS_SECRET="replace-with-secure-random-string"
# AUTH_JWT_REFRESH_SECRET="replace-with-different-secure-random-string"


# ── Email (Double Zero) ────────────────────────────────────────────────────
EMAIL_FROM="App Name <noreply@example.com>"
DOUBLE_ZERO_API_KEY="..."
DOUBLE_ZERO_API_ROUTE="https://email.example.com/"


# ── Shop Integration (optional — wenn mit node-shop verbunden) ─────────────
# SHOP_API_URL="http://localhost:8101"
# SHOP_API_KEY="..."


# ============================================================================
# API Key / OAuth2 Pepper Configuration (Versioned)
# ============================================================================
# Supports graceful pepper rotation without invalidating existing keys.
# See .env.api-keys.example for detailed rotation guide.

API_KEY_PEPPER_VERSION=1
API_KEY_PEPPER_V1=replace-with-random-secret-pepper-v1

OAUTH2_PEPPER_VERSION=1
# Optional: falls OAuth2-spezifischer Pepper gewuenscht.
# Wenn nicht gesetzt, wird API_KEY_PEPPER_V1 als Fallback genutzt.
# OAUTH2_PEPPER_V1=replace-with-random-oauth2-pepper-v1


# ============================================================================
# Entitlements Sync Integration (Receiver-only, Dual Auth)
# ============================================================================
# Diese App empfaengt Entitlement-Zuweisungen vom Shop.
#
# Mode 1: API Key — Authorization: Bearer <ENTITLEMENTS_SYNC_API_KEY>
# Mode 2: OAuth2  — Authorization: Bearer <access_token> (JWT, lokal verifiziert)
#
# OAuth2 Client Credentials werden ueber /oauth/clients/* verwaltet (DB-backed),
# NICHT ueber diese ENV-Variablen.

ENTITLEMENTS_SYNC_API_KEY=
ENTITLEMENTS_SYNC_OAUTH_ALLOWED_CLIENT_IDS=
